# ============================================================
# Message Integrate Agent - 生产环境变量模板
# ============================================================
#
# 复制此文件为 .env.prod 并填写实际配置
#
# ============================================================

# ==================== 基础配置 ====================
ENVIRONMENT=production
LOG_LEVEL=INFO

# ==================== 飞书配置 ====================
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_VERIFICATION_TOKEN=your_verification_token
FEISHU_ENCRYPT_KEY=your_encrypt_key
FEISHU_WEBHOOK_URL=your_feishu_webhook_url
FEISHU_CONNECTION_MODE=websocket

# ==================== Telegram 配置 ====================
TELEGRAM_BOT_TOKEN=your_telegram_token

# ==================== LLM 配置 ====================
# DeepSeek (用于生成中文标题/概要)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# OpenAI / Anthropic (备选)
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key

# ==================== Firecrawl 配置 ====================
# 用于抓取 Science.org 等网页
FIRECRAWL_API_KEY=your_firecrawl_api_key

# ==================== 搜索配置 ====================
TAVILY_API_KEY=your_tavily_api_key
GOOGLE_API_KEY=your_google_api_key

# ==================== 代理配置 ====================
# mihomo 运行在 NAS 上
HTTP_PROXY=http://192.168.1.2:7890
HTTPS_PROXY=http://192.168.1.2:7890
NO_PROXY=localhost,127.0.0.1,api.feishu.cn,open.feishu.cn,192.168.0.0/16

# ==================== PostgreSQL + pgvector (NAS) ====================
DATABASE_URL=postgresql://postgres:postgres@192.168.1.2:45041/bs_generator_db
PG_HOST=192.168.1.2
PG_PORT=45041
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=bs_generator_db

# ==================== Redis (NAS) ====================
REDIS_HOST=192.168.1.2
REDIS_PORT=40967
REDIS_DB=0

# ==================== S3/RustFs Storage (NAS) ====================
S3_ENDPOINT_URL=http://192.168.1.2:37163
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET_NAME=mightyoung
S3_REGION_NAME=us-east-1

# ==================== GitHub (可选) ====================
GITHUB_TOKEN=your_github_token

# ==================== ngrok (可选) ====================
NGROK_AUTHTOKEN=your_ngrok_token

# ==================== 定时任务配置 ====================
# Cron 格式: 分 时 日 月 周
# 学术论文推送（每天 9:00）
INTELLIGENCE_CRON_ACADEMIC=0 9 * * *

# GitHub Trending 推送（每天 10:00）
INTELLIGENCE_CRON_GITHUB=0 10 * * *

# Science 热点推送（每天 11:00）
INTELLIGENCE_CRON_SCIENCE=0 11 * * *

# SciRobotics 推送（每天 11:30）
INTELLIGENCE_CRON_SCIROBOTICS=0 11 30 * * *
