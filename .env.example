# Gateway Configuration
HOST=0.0.0.0
PORT=8080
DEBUG=false

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Feishu (Lark)
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_VERIFICATION_TOKEN=your_verification_token

# Feishu 连接模式 (可选)
# webhook: 需要暴露公网 URL (默认)
# websocket: 使用长连接，只需能访问外网
FEISHU_CONNECTION_MODE=websocket

# WeChat (Enterprise)
WECHAT_WEBHOOK_URL=your_wechat_webhook_url

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
DEFAULT_MODEL=gpt-4

# DeepSeek LLM (用于生成中文标题/概要)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Firecrawl (用于抓取 Science.org 等网页)
FIRECRAWL_API_KEY=your_firecrawl_api_key

# Search
TAVILY_API_KEY=your_tavily_api_key
GOOGLE_API_KEY=your_google_api_key
GOOGLE_CSE_ID=your_google_cse_id

# Proxy Configuration
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# VMESS (optional)
VMESS_SERVER=
VMESS_PORT=443
VMESS_UUID=
VMESS_ALTER_ID=0

# Shadowsocks (optional)
SS_SERVER=
SS_PORT=8388
SS_PASSWORD=
SS_CIPHER=aes-256-gcm

# GitHub (optional, for higher API rate limits)
GITHUB_TOKEN=

# PostgreSQL + pgvector (NAS)
DATABASE_URL=postgresql://postgres:postgres@192.168.1.2:45041/bs_generator_db
PG_HOST=192.168.1.2
PG_PORT=45041
PG_USER=postgres
PG_PASSWORD=postgres
PG_DB_NAME=intelligence_db

# Redis (NAS)
REDIS_HOST=192.168.1.2
REDIS_PORT=40967
REDIS_DB=0

# S3/RustFs Storage (NAS)
S3_ENDPOINT_URL=http://192.168.1.2:37163
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=mightyoung
S3_REGION_NAME=us-east-1

# Qwen Embedding (阿里云百炼)
QWEN_API_KEY=
QWEN_EMBEDDING_MODEL=text-embedding-v4

# ==================== Intelligence Scheduled Tasks ====================
# Cron 格式: 分 时 日 月 周
# 学术论文推送（每天 9:00）
INTELLIGENCE_CRON_ACADEMIC=0 9 * * *

# GitHub Trending 推送（每天 10:00）
INTELLIGENCE_CRON_GITHUB=0 10 * * *

# Science 热点推送（每天 11:00）
INTELLIGENCE_CRON_SCIENCE=0 11 * * *

# SciRobotics 推送（每天 11:30）
INTELLIGENCE_CRON_SCIROBOTICS=0 11 30 * * *
